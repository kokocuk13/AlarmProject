<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/timePickerContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="90dp"
                android:layout_height="70dp"
                android:background="@drawable/time_picker_bg"
                android:gravity="center"
                android:theme="@style/NumberPickerTheme"
                android:baselineAligned="false">
                <NumberPicker
                    android:id="@+id/hourPicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_separator"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <LinearLayout
                android:layout_width="90dp"
                android:layout_height="70dp"
                android:background="@drawable/time_picker_bg"
                android:gravity="center"
                android:theme="@style/NumberPickerTheme"
                android:baselineAligned="false">
                <NumberPicker
                    android:id="@+id/minutePicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/daysContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="7"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/timePickerContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button android:id="@+id/dayMon" style="@style/DayButton" android:text="@string/day_mon" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/dayTue" style="@style/DayButton" android:text="@string/day_tue" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/dayWed" style="@style/DayButton" android:text="@string/day_wed" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/dayThu" style="@style/DayButton" android:text="@string/day_thu" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/dayFri" style="@style/DayButton" android:text="@string/day_fri" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/daySat" style="@style/DayButton" android:text="@string/day_sat" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/daySun" style="@style/DayButton" android:text="@string/day_sun" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/dismissMethodContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/daysContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/shakeCard"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/dismiss_card_selected"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_rotate"
                    android:contentDescription="@string/task_shake_cd" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/task_shake_label"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/barcodeCard"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/dismiss_card_normal"
                android:layout_marginStart="8dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:contentDescription="@string/task_barcode_cd"
                    android:scaleType="fitCenter" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/task_barcode_label"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/shakeCountContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dismissMethodContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/shake_count_label"
                android:textSize="13sp"
                android:textColor="#333333" />

            <SeekBar
                android:id="@+id/shakeCountSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="50"
                android:min="1"
                android:progress="20"
                android:progressTint="#6B4EFF"
                android:thumbTint="#6B4EFF"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="5">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="10" android:textSize="11sp" android:textColor="#888888" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="20" android:textSize="11sp" android:textColor="#888888" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="30" android:textSize="11sp" android:textColor="#888888" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="40" android:textSize="11sp" android:textColor="#888888" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="50" android:textSize="11sp" android:textColor="#888888" android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/barcodeControlsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/shakeCountContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/scanBarcodeButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/scan_barcode_btn"
                android:textColor="@android:color/white"
                android:backgroundTint="#6B4EFF" />

            <TextView
                android:id="@+id/selectedBarcodeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/barcode_not_selected"
                android:textSize="13sp"
                android:textColor="#555555" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/melodyRow"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/barcodeControlsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/melody_label"
                android:textSize="15sp"
                android:textColor="#000000" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_play"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/melody_label" />

            <TextView
                android:id="@+id/melodyName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/melody_default"
                android:textSize="15sp"
                android:textColor="#555555"
                android:layout_marginStart="8dp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/arrow_down_float"
                android:contentDescription="@string/select_melody_cd" />

        </LinearLayout>

        <EditText
            android:id="@+id/alarmNameInput"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:hint="@string/alarm_name_hint"
            android:textColor="#000000"
            android:textColorHint="#999999"
            android:textSize="15sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_bg"
            android:inputType="text"
            android:autofillHints="none"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/melodyRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="@string/save_button"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#6B4EFF"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/alarmNameInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
