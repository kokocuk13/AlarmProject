<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Настройка будильника"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/timePickerContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="90dp"
                android:layout_height="70dp"
                android:background="@drawable/time_picker_bg"
                android:gravity="center">
                <NumberPicker
                    android:id="@+id/hourPicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:theme="@style/NumberPickerTheme" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=":"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <LinearLayout
                android:layout_width="90dp"
                android:layout_height="70dp"
                android:background="@drawable/time_picker_bg"
                android:gravity="center">
                <NumberPicker
                    android:id="@+id/minutePicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:theme="@style/NumberPickerTheme" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/daysContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="7"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/timePickerContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button android:id="@+id/dayMon" style="@style/DayButton" android:text="ПН" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/dayTue" style="@style/DayButton" android:text="ВТ" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/dayWed" style="@style/DayButton" android:text="СР" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/dayThu" style="@style/DayButton" android:text="ЧТ" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/dayFri" style="@style/DayButton" android:text="ПТ" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/daySat" style="@style/DayButton" android:text="СБ" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />
            <Button android:id="@+id/daySun" style="@style/DayButton" android:text="ВС" android:layout_weight="1" android:layout_width="0dp" android:layout_height="36dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/dismissMethodContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/daysContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/shakeCard"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/dismiss_card_selected"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_rotate"
                    android:contentDescription="Тряска" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Трясти телефон"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/barcodeCard"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/dismiss_card_normal"
                android:layout_marginStart="8dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:contentDescription="Штрих-код"
                    android:scaleType="fitCenter" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Штрих-код"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/shakeCountContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dismissMethodContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Количество встряхиваний"
                android:textSize="13sp"
                android:textColor="#333333" />

            <SeekBar
                android:id="@+id/shakeCountSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="40"
                android:progress="20"
                android:progressTint="#6B4EFF"
                android:thumbTint="#6B4EFF"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="5">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="10" android:textSize="11sp" android:textColor="#888888" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="20" android:textSize="11sp" android:textColor="#888888" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="30" android:textSize="11sp" android:textColor="#888888" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="40" android:textSize="11sp" android:textColor="#888888" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="50" android:textSize="11sp" android:textColor="#888888" android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/barcodeControlsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/shakeCountContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/scanBarcodeButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Сканировать штрих-код"
                android:textColor="@android:color/white"
                android:backgroundTint="#6B4EFF" />

            <TextView
                android:id="@+id/selectedBarcodeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Штрих-код не выбран"
                android:textSize="13sp"
                android:textColor="#555555" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/melodyRow"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/barcodeControlsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Мелодия"
                android:textSize="15sp"
                android:textColor="#000000" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_play"
                android:layout_marginStart="12dp"
                android:contentDescription="Мелодия" />

            <TextView
                android:id="@+id/melodyName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Звуки природы"
                android:textSize="15sp"
                android:textColor="#555555"
                android:layout_marginStart="8dp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/arrow_down_float"
                android:contentDescription="Выбрать" />

        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/alarmNameLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Название будильника"
            android:layout_marginTop="16dp"
            app:boxStrokeColor="#6B4EFF"
            app:hintTextColor="#6B4EFF"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:layout_constraintTop_toBottomOf="@id/melodyRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/alarmNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:theme="@style/NumberPickerTheme" />

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/saveButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="Сохранить"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#6B4EFF"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/alarmNameLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
