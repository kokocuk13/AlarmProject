<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.AlarmProject" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#6B4EFF</item>
        <item name="colorPrimaryVariant">#5B3EEF</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#03DAC6</item>
        <item name="colorSecondaryVariant">#018786</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="android:statusBarColor">#6B4EFF</item>
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!-- Тема для NumberPicker: принудительно чёрный текст -->
    <style name="NumberPickerTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:textColor">#000000</item>
        <item name="android:textColorPrimary">#000000</item>
        <item name="android:textColorSecondary">#000000</item>
        <item name="android:colorControlNormal">#6B4EFF</item>
        <item name="colorControlNormal">#6B4EFF</item>
    </style>

    <style name="DayButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:textSize">12sp</item>
        <item name="cornerRadius">8dp</item>
        <item name="backgroundTint">#F0F0F0</item>
        <item name="android:textColor">#333333</item>
    </style>

</resources>
